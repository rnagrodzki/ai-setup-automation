---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkflowGraph from '../../components/WorkflowGraph.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Learning & Improvement Workflow" description="How aisa-postmortem, aisa-harvest, and aisa-lint turn incidents into better AI configuration.">
  <section class="wd-hero">
    <div class="wd-hero-inner">
      <a href={`${base}/workflows/`} class="wd-back">&larr; All Workflows</a>
      <span class="wd-overline" style="--lane-color: var(--color-utilities);">Learn Lane</span>
      <h1 class="wd-title">Learning & Improvement</h1>
      <p class="wd-subtitle">
        Mistakes become skills. Here's how incidents and experience flow back into your AI configuration.
      </p>
    </div>
  </section>

  <section class="wd-graph-section">
    <div class="wd-graph-container">
      <WorkflowGraph highlightSlugs={['postmortem', 'harvest', 'lint']} />
    </div>
  </section>

  <section class="wd-content">
    <div class="wd-content-inner">
      <div class="wd-steps">
        <div class="wd-step" style="--step-color: var(--color-essentials);">
          <div class="wd-step-marker">1</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Run a postmortem with
              <a href={`${base}/skills/aisa-postmortem/`} class="wd-skill-link">/aisa-postmortem</a>
            </h2>
            <p>
              After an incident or painful debugging session, postmortem gathers context from the
              conversation, git history, or interactive questions. It maps each root cause to skill
              gaps — missing rules, absent gotchas, incomplete quality gates.
            </p>
            <p>
              The output is concrete: specific content to add to specific skills, plus learning
              entries categorized as GOTCHA, PATTERN_FAILED, DOC_GAP, DEPENDENCY_QUIRK, or
              CONVENTION_VIOLATION.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-utilities);">
          <div class="wd-step-marker">2</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Promote learnings with
              <a href={`${base}/skills/aisa-harvest/`} class="wd-skill-link">/aisa-harvest</a>
            </h2>
            <p>
              Run when the learning log has 10+ active entries. Harvest clusters them by theme,
              identifies which deserve promotion to existing skills, which justify new skills, and
              which should update documentation.
            </p>
            <p>
              Promoted content goes directly into skill files — gotcha sections, anti-patterns,
              code examples. Learning entries get marked as PROMOTED or STALE, keeping the log
              clean.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-analysis);">
          <div class="wd-step-marker">3</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Validate with
              <a href={`${base}/skills/aisa-lint/`} class="wd-skill-link">/aisa-lint</a>
            </h2>
            <p>
              After changes from postmortem or harvest, lint validates everything against
              architectural principles P1-P3 (skills) and A1-A6 (agents). It checks structural
              completeness, PCIDCI pattern compliance, and capability-tool consistency.
            </p>
            <p>
              Lint catches issues that content changes might introduce — a promoted gotcha that
              breaks the self-learning directive format, a new skill missing quality gates, an
              agent with invalid tool references.
            </p>
          </div>
        </div>
      </div>

      <div class="wd-after">
        <h2 class="wd-after-title">What happens next?</h2>
        <div class="wd-after-paths">
          <a href={`${base}/workflows/continuous-evolution/`} class="wd-after-path" style="--path-color: var(--color-analysis);">
            <span class="wd-path-label">Keep evolving</span>
            <span class="wd-path-desc">The improved skills feed back into the maintenance cycle via inspect and update</span>
          </a>
          <a href={`${base}/workflows/first-setup/`} class="wd-after-path" style="--path-color: var(--color-essentials);">
            <span class="wd-path-label">Start fresh</span>
            <span class="wd-path-desc">For new projects, scaffold from scratch with the lessons already encoded</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wd-hero {
    padding: 3rem 1.5rem 1.5rem;
  }

  .wd-hero-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .wd-back {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: color 0.12s ease;
  }

  .wd-back:hover {
    color: var(--color-text);
  }

  .wd-overline {
    display: inline-block;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lane-color);
    margin-bottom: 0.75rem;
    padding: 3px 10px;
    border: 1px solid color-mix(in srgb, var(--lane-color) 30%, transparent);
    border-radius: 4px;
    background: color-mix(in srgb, var(--lane-color) 8%, transparent);
  }

  .wd-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .wd-subtitle {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .wd-graph-section {
    padding: 1rem 1.5rem 2rem;
  }

  .wd-graph-container {
    max-width: 72rem;
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    padding: 1.5rem;
    overflow: hidden;
  }

  .wd-content {
    padding: 0 1.5rem 3rem;
  }

  .wd-content-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  /* --- Steps --- */
  .wd-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .wd-step {
    display: flex;
    gap: 1.25rem;
    position: relative;
  }

  .wd-step-marker {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--step-color) 15%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--step-color) 40%, transparent);
    color: var(--step-color);
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.125rem;
  }

  .wd-step-body {
    flex: 1;
    min-width: 0;
  }

  .wd-step-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.625rem;
    line-height: 1.4;
  }

  .wd-skill-link {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9375rem;
    color: var(--step-color);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--step-color) 30%, transparent);
    transition: border-color 0.12s ease;
  }

  .wd-skill-link:hover {
    border-color: var(--step-color);
  }

  .wd-step-body p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .wd-step-body p:last-child {
    margin-bottom: 0;
  }

  /* --- After section --- */
  .wd-after-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .wd-after-paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .wd-after-path {
    display: block;
    padding: 1rem 1rem 1rem 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--path-color);
    border-radius: 6px;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .wd-after-path:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 12px -2px color-mix(in srgb, var(--path-color) 15%, transparent);
  }

  .wd-path-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .wd-path-desc {
    display: block;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .wd-hero {
      padding: 2rem 1rem 1rem;
    }

    .wd-graph-section,
    .wd-content {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .wd-graph-container {
      padding: 1rem;
    }

    .wd-after-paths {
      grid-template-columns: 1fr;
    }
  }
</style>
